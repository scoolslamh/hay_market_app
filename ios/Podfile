platform :ios, '14.0'

# محاولة تحميل إعدادات فلاتر بدون إجبار (بدون تعليق البناء)
flutter_install_utils = File.join(File.dirname(__FILE__), 'Flutter', 'generated_ios_development_target.rb')
load flutter_install_utils if File.exist?(flutter_install_utils)

target 'Runner' do
  use_frameworks!
  use_flutter_plugins!
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      # حل مشكلة الـ ARCHS الشائعة في السيرفرات
      config.build_settings['ONLY_ACTIVE_ARCH'] = 'YES'
    end
  end
end